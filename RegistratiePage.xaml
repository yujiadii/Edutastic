<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Edutastic.RegistratiePage">
    
    
    <Grid Padding="30">

        <VerticalStackLayout
            VerticalOptions="Center"
            Spacing="24">
            
            <VerticalStackLayout Spacing="6">

                <Label
                    Text="Maak account"
                    FontSize="34"
                    FontAttributes="Bold"
                    TextColor="#222" />

                <Label
                    Text="Start nu met leren!"
                    FontSize="15"
                    TextColor="#777" />

            </VerticalStackLayout>
            
            <Entry
                Placeholder="E-mail"
                BackgroundColor="White"
                TextColor="#222"
                PlaceholderColor="#999"
                HeightRequest="55"
                Margin="0,10,0,0" />
            
            <Entry
                Placeholder="Gebruikersnaam"
                BackgroundColor="White"
                TextColor="#222"
                PlaceholderColor="#999"
                HeightRequest="55" />
            
            <Entry
                Placeholder="Wachtwoord"
                IsPassword="True"
                BackgroundColor="White"
                TextColor="#222"
                PlaceholderColor="#999"
                HeightRequest="55" />
            
            <Button
                Text="Registreren"
                HeightRequest="55"
                BackgroundColor="#222"
                TextColor="White"
                CornerRadius="14"
                FontAttributes="Bold" />
            
            <HorizontalStackLayout
                HorizontalOptions="Center"
                Spacing="4">
                

            </HorizontalStackLayout>

        </VerticalStackLayout>

    </Grid>

</ContentPage>